--ip_version=ipv6
--local_ip=fd3d:fa7b:d17d::2
--gateway_ip=fd3d:fa7b:d17d::1
--remote_ip=2001:db8::1

`$TCP_IP_PD_CASE setup ipv6`

0.000 socket(..., SOCK_STREAM, IPPROTO_TCP) = 3
+0.000 setsockopt(3, SOL_SOCKET, SO_REUSEADDR, [1], 4) = 0
+0.000 bind(3, ..., ...) = 0
+0.000 listen(3, 1) = 0
+0.000 `$TCP_IP_PD_CASE ctl listen [fd3d:fa7b:d17d::2]:8080`
+0.010 < S 0:0(0) win 65535 <mss 1000,sackOK,nop,nop,nop,wscale 0>
+0.000 > S. 0:0(0) ack 1 win 65535 <...>
+0.000 < . 1:1(0) ack 1 win 65535

+0.010 `$TCP_IP_PD_CASE ctl shutdown-write`
+0.000 > F. 1:1(0) ack 1
// Drop the first FIN and require it to be retransmitted at the configured RTO.
+0.150~+0.450 > F. 1:1(0) ack 1
+0.000 < . 1:1(0) ack 2 win 65535
+0.010 < F. 1:1(0) ack 2 win 65535
+0.000 > . 2:2(0) ack 2
+0.010 `$TCP_IP_PD_CASE ctl expect-eof`

// The socket must remain in TIME_WAIT and ACK a retransmitted peer FIN.
+0.200 < F. 1:1(0) ack 2 win 65535
+0.000 > . 2:2(0) ack 2

`$TCP_IP_PD_CASE cleanup`
